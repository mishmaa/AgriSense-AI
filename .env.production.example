PROJECT_NAME=AgriSense AI
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

POSTGRES_USER=agrisense
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=agrisense
DATABASE_URL=postgresql+psycopg://agrisense:replace-with-strong-password@postgres:5432/agrisense

JWT_SECRET_KEY=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=45
DOCS_ENABLED=false
GZIP_MINIMUM_SIZE=1024

BACKEND_CORS_ORIGINS=https://your-domain.com
TRUSTED_HOSTS=your-domain.com,backend,localhost

VITE_API_BASE_URL=https://your-domain.com/api/v1
VITE_WS_BASE_URL=wss://your-domain.com

WEATHER_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_PROVIDER_API_KEY=
